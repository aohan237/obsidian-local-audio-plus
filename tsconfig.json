{
  "compilerOptions": {
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "ES2018",
    "lib": ["DOM", "ES2018"],
    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "importHelpers": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"]
}
